{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "integratedTaskIds",
    "deferredTaskIds",
    "checks",
    "conflicts",
    "pushRecommended"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["integrated", "no-op", "blocked", "failed"]
    },
    "summary": { "type": "string" },
    "integratedTaskIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deferredTaskIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "result", "durationSeconds"],
        "properties": {
          "command": { "type": "string" },
          "result": { "type": "string" },
          "durationSeconds": { "type": "number" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pushRecommended": { "type": "boolean" }
  }
}
