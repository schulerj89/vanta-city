{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "approvedTaskIds", "deferred", "conflicts"],
  "properties": {
    "summary": { "type": "string" },
    "approvedTaskIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "deferred": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "reason"],
        "properties": {
          "taskId": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
