{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "assignments", "deferred"],
  "properties": {
    "summary": { "type": "string" },
    "assignments": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "taskId",
          "rationale",
          "scope",
          "validationFocus",
          "overlapRisks"
        ],
        "properties": {
          "taskId": { "type": "string" },
          "rationale": { "type": "string" },
          "scope": { "type": "string" },
          "validationFocus": {
            "type": "array",
            "items": { "type": "string" }
          },
          "overlapRisks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "deferred": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["taskId", "reason"],
        "properties": {
          "taskId": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
