{
  "version": 1,
  "always": [
    { "id": "format", "args": ["format:check"], "timeoutMinutes": 3 },
    { "id": "lint", "args": ["lint"], "timeoutMinutes": 5 },
    { "id": "typecheck", "args": ["typecheck"], "timeoutMinutes": 5 },
    { "id": "unit", "args": ["test"], "timeoutMinutes": 5 },
    { "id": "build", "args": ["build"], "timeoutMinutes": 8 },
    { "id": "bundle-size", "args": ["size"], "timeoutMinutes": 2 },
    {
      "id": "smoke",
      "args": ["test:e2e:smoke"],
      "timeoutMinutes": 5,
      "browser": true
    }
  ],
  "tasks": {
    "CORE-001": ["e2e/playable-debug-smoke.spec.ts"],
    "WORLD-001": [
      "e2e/district-location-hud.spec.ts",
      "e2e/collision-geometry.spec.ts",
      "e2e/sector-streaming-performance.spec.ts"
    ],
    "NPC-001": [
      "e2e/character-animation-lab.spec.ts",
      "e2e/conversation-slice.spec.ts"
    ],
    "MISSION-001": ["e2e/interaction-reliability.spec.ts"],
    "VEHICLE-001": ["e2e/traffic.spec.ts"],
    "MAP-001": ["e2e/minimap-hud.spec.ts"],
    "CINEMATIC-001": [
      "e2e/conversation-camera.spec.ts",
      "e2e/camera-composition-lab.spec.ts"
    ],
    "MISSION-002": ["e2e/conversation-slice.spec.ts"],
    "PRESENTATION-001": ["e2e/performance-loading.spec.ts"],
    "AUDIO-001": ["e2e/playable-debug-smoke.spec.ts"],
    "UI-SYSTEM-001": [
      "e2e/playable-debug-smoke.spec.ts",
      "e2e/gamepad-accessibility.spec.ts"
    ],
    "QA-PLAYBOT-001": ["e2e/diagnostic-recorder.spec.ts"],
    "TEST-001": ["e2e/playable-debug-smoke.spec.ts"]
  },
  "assetValidators": [
    {
      "id": "characters",
      "pathPatterns": ["character", "public/assets/characters"],
      "args": ["validate:characters"]
    },
    {
      "id": "equipment",
      "pathPatterns": ["equipment", "weapon"],
      "args": ["validate:equipment"]
    },
    {
      "id": "intersection",
      "pathPatterns": ["intersection", "src/world"],
      "args": ["validate:intersection"]
    },
    {
      "id": "buildings",
      "pathPatterns": ["building"],
      "args": ["validate:buildings"]
    },
    {
      "id": "traffic",
      "pathPatterns": ["traffic", "vehicle", "public/assets/vehicles"],
      "args": ["validate:traffic"]
    },
    {
      "id": "narrative",
      "pathPatterns": ["narrative", "dialogue", "mission", "cinematic"],
      "args": ["validate:narrative"]
    }
  ]
}
