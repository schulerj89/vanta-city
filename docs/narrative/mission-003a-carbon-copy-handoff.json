  "conversationDefinitionDraft": {
    "id": "conversation.nox.check-in",
    "canCancel": true,
    "lines": [
      {
        "id": "dialogue.ash-002.nox.orin-code",
        "speakerId": "nox",
        "text": "Orin wrote ‘Rook’ beside this yard. He left a transfer code.",
        "portraitPresentation": "none",
        "nextLine": "dialogue.ash-002.rook.not-chain"
      },
      {
        "id": "dialogue.ash-002.rook.not-chain",
        "speakerId": "rook",
        "text": "A code is not a chain.",
        "portraitPresentation": "none",
        "nextLine": "dialogue.ash-002.nox.venue"
      },
      {
        "id": "dialogue.ash-002.nox.venue",
        "speakerId": "nox",
        "text": "Della has the matching impound book. Night venue, eleven.",
        "portraitPresentation": "none",
        "nextLine": "dialogue.ash-002.rook.marrow"
      },
      {
        "id": "dialogue.ash-002.rook.marrow",
        "speakerId": "rook",
        "text": "You invited Marrow?",
        "portraitPresentation": "none",
        "nextLine": "dialogue.ash-002.nox.two-doors"
      },
      {
        "id": "dialogue.ash-002.nox.two-doors",
        "speakerId": "nox",
        "text": "She invited you. I get the second door.",
        "portraitPresentation": "none",
        "nextLine": "dialogue.ash-002.rook.cash"
      },
      {
        "id": "dialogue.ash-002.rook.cash",
        "speakerId": "rook",
        "text": "And the cash?",
        "portraitPresentation": "none",
        "nextLine": "dialogue.ash-002.nox.witness"
      },
      {
        "id": "dialogue.ash-002.nox.witness",
        "speakerId": "nox",
        "text": "Easier than a witness. That is why she brings it.",
        "portraitPresentation": "none"
      }
    ]
  },
