{
  "name": "vanta-city",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:profile": "node scripts/profile-tests.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:feature": "playwright test --grep-invert @visual",
    "test:e2e:visual": "playwright test --grep @visual",
    "test:e2e:full": "playwright test",
    "test:e2e:profile:parallel": "playwright test --workers=2",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install chromium",
    "sandbox": "vite --open '/?sandbox=foundation&debug=1'",
    "camera-lab": "vite --open '/?sandbox=camera-composition&debug=1'",
    "lab:characters": "vite --open '/?sandbox=character-animation-lab&debug=1'",
    "lab:buildings": "vite --open '/?sandbox=building-visual-lab&debug=1'",
    "size": "node scripts/report-bundle-size.mjs",
    "validate:characters": "tsx scripts/validate-characters.ts",
    "validate:equipment": "tsx scripts/validate-equipment-assets.ts",
    "validate:intersection": "tsx scripts/validate-intersection-assets.ts",
    "validate:buildings": "tsx scripts/validate-building-assets.ts",
    "validate:traffic": "tsx scripts/validate-traffic-assets.ts"
  },
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.10.13",
    "@types/three": "^0.185.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.7.0"
}
